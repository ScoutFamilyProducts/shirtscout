PORT=3000
NODE_ENV=development

# Walmart Affiliate Open API v2
# Consumer ID from https://developer.walmart.com (your account's Consumer ID)
WALMART_CONSUMER_ID=
# RSA private key in PEM format — newlines must be replaced with \n for .env storage
WALMART_PRIVATE_KEY=
# Key version shown in your Walmart IO key management page (usually "1")
WALMART_KEY_VERSION=1

# eBay Browse API (OAuth client credentials)
# App ID (Client ID) and Cert ID (Client Secret) from https://developer.ebay.com
EBAY_APP_ID=
EBAY_CERT_ID=
# Dev ID is not used by Browse API but kept for future Trading API use
EBAY_DEV_ID=
# eBay Partner Network campaign ID — enables affiliate rover URLs on search results
# Found at: https://partnernetwork.ebay.com → Campaigns
EBAY_CAMPAIGN_ID=5339151103

# Amazon Associates Product Advertising API 5.0 (PAAPI 5.0)
# IMPORTANT: Amazon requires 10 qualifying referral sales before granting
# PAAPI access. Until then the connector runs in mock mode automatically.
# Credentials are from https://affiliate-program.amazon.com → Tools → Product Advertising API
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=shirtscout-20
AMAZON_HOST=webservices.amazon.com
AMAZON_REGION=us-east-1
# Set to "true" to force mock mode even when credentials are present (e.g. dev/test)
AMAZON_MOCK=false

# Cache TTL in seconds
CACHE_TTL=300
